{
  "name": "alert",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/alert/src",
  "prefix": "lib",
  "projectType": "library",
  "release": {
    "version": {
      "manifestRootsToUpdate": ["dist/{projectRoot}"],
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk"
    }
  },
  "tags": ["scope:shared"],
  "targets": {
    "build": {
      "executor": "@nx/angular:package",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "project": "packages/alert/ng-package.json",
        "tsConfig": "packages/alert/tsconfig.lib.json"
      },
      "configurations": {
        "production": { "tsConfig": "packages/alert/tsconfig.lib.prod.json" },
        "development": {}
      },
      "defaultConfiguration": "production"
    },
    "nx-release-publish": { "options": { "packageRoot": "dist/{projectRoot}" } },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "packages/alert/jest.config.cts",
        "tsConfig": "packages/alert/tsconfig.spec.json"
      }
    },
    "lint": { "executor": "@nx/eslint:lint" }
  }
}
