{
  "duration": {
    "micro":  { "$value": "100ms" },
    "fast":   { "$value": "150ms" },
    "base":   { "$value": "200ms" },
    "slow":   { "$value": "300ms" },
    "enter":  { "$value": "250ms" },
    "exit":   { "$value": "200ms" },
    "expand": { "$value": "300ms" }
  },
  "easing": {
    "spring-enter": { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)" },
    "spring-exit":  { "$value": "cubic-bezier(0.36, 0, 0.66, -0.56)" },
    "smooth":       { "$value": "cubic-bezier(0.4, 0, 0.2, 1)" },
    "snap":         { "$value": "cubic-bezier(0.4, 0, 1, 1)" },
    "ease-out":     { "$value": "cubic-bezier(0, 0, 0.2, 1)" },
    "ease-in":      { "$value": "cubic-bezier(0.4, 0, 1, 1)" }
  }
}
