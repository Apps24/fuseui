{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "projects": {
    "shop": {
      "root": "apps/shop",
      "sourceRoot": "apps/shop/src",
      "projectType": "application",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/apps/shop",
            "browser": "apps/shop/src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "apps/shop/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "apps/shop/public"
              }
            ],
            "styles": [
              "apps/shop/src/styles.css"
            ]
          },
          "configurations": {
            "production": {
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            },
            "ci": {
              "outputMode": "static",
              "outputHashing": "none",
              "prerender": false
            }
          },
          "defaultConfiguration": "production"
        }
      }
    },
    "core": {
      "root": "packages/core",
      "sourceRoot": "packages/core/src",
      "projectType": "library",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "packages/core/ng-package.json",
            "tsConfig": "packages/core/tsconfig.lib.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "packages/core/tsconfig.lib.prod.json"
            }
          }
        },
        "storybook": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": "packages/core/.storybook",
            "browserTarget": "shop:build:development",
            "compodoc": false,
            "port": 6006
          }
        },
        "build-storybook": {
          "builder": "@storybook/angular:build-storybook",
          "options": {
            "configDir": "packages/core/.storybook",
            "browserTarget": "shop:build:production",
            "compodoc": false,
            "outputDir": "packages/core/storybook-static"
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}