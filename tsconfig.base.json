{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@fuse_ui/core": ["packages/core/src/index.ts"],
      "@fuse_ui/button": ["packages/button/src/index.ts"],
      "@fuse_ui/icon": ["packages/icon/src/index.ts"],
      "@fuse_ui/input": ["packages/input/src/index.ts"],
      "@fuse_ui/label": ["packages/label/src/index.ts"],
      "@fuse_ui/select": ["packages/select/src/index.ts"],
      "@fuse_ui/checkbox": ["packages/checkbox/src/index.ts"],
      "@fuse_ui/card": ["packages/card/src/index.ts"],
      "@fuse_ui/badge": ["packages/badge/src/index.ts"],
      "@fuse_ui/avatar": ["packages/avatar/src/index.ts"],
      "@fuse_ui/skeleton": ["packages/skeleton/src/index.ts"],
      "@fuse_ui/toast": ["packages/toast/src/index.ts"],
      "@fuse_ui/modal": ["packages/modal/src/index.ts"],
      "@fuse_ui/alert": ["packages/alert/src/index.ts"],
      "@fuse_ui/spinner": ["packages/spinner/src/index.ts"],
      "@fuse_ui/tabs": ["packages/tabs/src/index.ts"],
      "@fuse_ui/accordion": ["packages/accordion/src/index.ts"],
      "@fuse_ui/chip": ["packages/chip/src/index.ts"],
      "@fuse_ui/tooltip": ["packages/tooltip/src/index.ts"],
      "@fuse_ui/popover": ["packages/popover/src/index.ts"],
      "@fuse_ui/dropdown": ["packages/dropdown/src/index.ts"],
      "@fuse_ui/breadcrumb": ["packages/breadcrumb/src/index.ts"],
      "@fuse_ui/pagination": ["packages/pagination/src/index.ts"],
      "@fuse_ui/slider": ["packages/slider/src/index.ts"],
      "@fuse_ui/form-field": ["packages/form-field/src/index.ts"],
      "@fuse_ui/empty-state": ["packages/empty-state/src/index.ts"],
      "@fuse_ui/table": ["packages/table/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
